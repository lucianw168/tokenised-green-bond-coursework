# ── Testnet RPC (fill in ONE of these) ───────────────────
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
HOLESKY_RPC_URL=https://eth-holesky.g.alchemy.com/v2/YOUR_KEY

# ── Etherscan verification ──────────────────────────────
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ── Wallet private keys (NEVER commit real keys) ────────
# You need 4 wallets to run the full demo on a public testnet.
# Create them in MetaMask, export private keys, and fund each
# with a small amount of testnet ETH from a faucet.
#
# Role mapping:
#   DEPLOYER  = Issuer/Admin   (deploys, whitelists, mints, pauses)
#   INVESTOR_A = Investor A    (receives issuance, transfers, redeems)
#   INVESTOR_B = Investor B    (receives secondary transfer)
#   UNAPPROVED = Unapproved    (proves transfer restriction)

DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
INVESTOR_A_PRIVATE_KEY=0xYOUR_INVESTOR_A_PRIVATE_KEY
INVESTOR_B_PRIVATE_KEY=0xYOUR_INVESTOR_B_PRIVATE_KEY
UNAPPROVED_PRIVATE_KEY=0xYOUR_UNAPPROVED_PRIVATE_KEY
